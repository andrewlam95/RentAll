<%- include('partials/header') %>

<div class="container py-5">
    <div class="row">
        <!-- Profile Header -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-2">
                            <div class="profile-avatar text-center">
                                <i class="bi bi-person-circle fs-1 text-primary"></i>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <h3><%= user.name %></h3>
                            <p class="text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> <%= user.location %> • Member since <%= user.memberSince %>
                            </p>
                            <div class="rating">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <% if(i <= Math.floor(user.rating)) { %>
                                        <i class="bi bi-star-fill text-warning"></i>
                                    <% } else if(i === Math.ceil(user.rating) && user.rating % 1 !== 0) { %>
                                        <i class="bi bi-star-half text-warning"></i>
                                    <% } else { %>
                                        <i class="bi bi-star text-warning"></i>
                                    <% } %>
                                <% } %>
                                <span class="ms-2"><%= user.rating %> (<%= user.reviewCount %> reviews)</span>
                            </div>
                            <% if(user.bio) { %>
                                <p class="mt-2 mb-0"><%= user.bio %></p>
                            <% } %>
                        </div>
                        <div class="col-md-2 text-end">
                            <button class="btn btn-outline-primary">
                                <i class="bi bi-chat"></i> Message
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Stats</h5>
                </div>
                <div class="card-body">
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Items Listed</h6>
                        <h4 class="text-primary"><%= user.itemsListed %></h4>
                    </div>
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Total Rentals</h6>
                        <h4 class="text-primary"><%= user.totalRentals %></h4>
                    </div>
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Earnings</h6>
                        <h4 class="text-primary">$<%= user.earnings %></h4>
                    </div>
                    <div class="stat-item">
                        <h6 class="text-muted">Response Rate</h6>
                        <h4 class="text-primary"><%= user.responseRate %>%</h4>
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Contact</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-chat me-2"></i> Send Message
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-phone me-2"></i> Call Owner
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-shield-check me-2"></i> Report Issue
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h4 class="mb-4"><%= user.name %>'s Listings</h4>
            
            <div class="row">
                <% user.items.forEach(item => { %>
                    <div class="col-md-6 mb-4">
                        <div class="card">
                            <img src="<%= item.image %>" class="card-img-top" alt="<%= item.title %>" style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <h6 class="card-title"><%= item.title %></h6>
                                <p class="card-text text-muted">$<%= item.price %>/day</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-success">Available</span>
                                    <a href="/product/<%= item.id %>" class="btn btn-sm btn-outline-primary">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %> 