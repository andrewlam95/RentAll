<%- include('partials/header') %>

<div class="container rental-container py-5">
    <div class="row">
        <!-- Product Images Gallery -->
        <div class="col-md-6">
            <h1 class="mb-3"><%= item.title %></h1>
            <div class="product-gallery">
                <!-- Main Image Container -->
                <div class="main-image-container position-relative">
                    <img src="<%= item.image %>" class="main-image img-fluid rounded" alt="<%= item.title %>" id="mainImage">
                    
                    <!-- Navigation Arrows -->
                    <button class="gallery-nav-btn gallery-nav-prev" onclick="changeImage(-1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="gallery-nav-btn gallery-nav-next" onclick="changeImage(1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    
                    <!-- Image Counter -->
                    <div class="image-counter">
                        <span id="currentImageIndex">1</span>/<span id="totalImages">4</span>
                    </div>
                </div>
                
                <!-- Thumbnail Gallery -->
                <div class="thumbnail-gallery mt-3">
                    <div class="thumbnail-container">
                        <div class="thumbnail active" onclick="selectImage(0)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(1)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(2)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(3)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(4)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(5)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(6)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(7)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(8)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(9)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(10)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                        <div class="thumbnail" onclick="selectImage(11)" data-image="<%= item.image %>">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="img-fluid">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Details moved below images -->
            <div class="product-info mt-4">
                <div class="mb-3">
                    <span class="badge bg-primary fs-6"><%= item.category %></span>
                    <span class="text-muted ms-2"><i class="bi bi-geo-alt"></i> <%= item.location %></span>
                </div>

                <div class="price-section mb-4">
                    <h2 class="text-primary">$<%= item.price %>/day</h2>
                    <p class="text-muted">Rental price per day</p>
                </div>

                <div class="description mb-0">
                    <h5>Description</h5>
                    <p><%= item.description %></p>
                </div>
            </div>

            <!-- Owner Info -->
            <div class="owner-info mb-4 mt-4">
                <h5>Owner</h5>
                <div class="d-flex align-items-start justify-content-between">
                    <div class="d-flex align-items-start flex-grow-1">
                        <div class="avatar me-3">
                            <i class="bi bi-person-circle fs-2"></i>
                        </div>
                        <div class="flex-grow-1">
                            <a href="/user/1" class="text-decoration-none">
                                <h6 class="mb-1 text-primary">John Doe</h6>
                            </a>
                            <div class="d-flex align-items-center flex-wrap gap-2">
                                <p class="text-muted mb-0">Member since 2023</p>
                                <div class="rating d-flex align-items-center">
                                    <div class="d-flex align-items-center me-2">
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <i class="bi bi-star text-warning"></i>
                                    </div>
                                    <span>4.8 (15 reviews)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="message-owner-wrapper ms-3">
                        <button type="button" class="btn btn-outline-primary message-owner-btn" data-bs-toggle="modal" data-bs-target="#messageOwnerModal">
                            <i class="bi bi-envelope me-1"></i> Message Owner
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-md-6">
            <!-- Booking Form -->
            <div class="booking-form" id="bookingFormContainer">
                <form id="bookingForm">
                    <div class="mb-3">
                        <input type="hidden" id="startDate" required>
                        <input type="hidden" id="endDate" required>
                        <div class="calendar-section booking-calendar-compact">
                            <div class="calendar-container">
                                <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="bookingPrevMonth">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                    <h6 class="mb-0" id="bookingCurrentMonth">December 2024</h6>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="bookingNextMonth">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                                <div class="calendar-weekdays">
                                    <div class="calendar-weekday">Sun</div>
                                    <div class="calendar-weekday">Mon</div>
                                    <div class="calendar-weekday">Tue</div>
                                    <div class="calendar-weekday">Wed</div>
                                    <div class="calendar-weekday">Thu</div>
                                    <div class="calendar-weekday">Fri</div>
                                    <div class="calendar-weekday">Sat</div>
                                </div>
                                <div class="calendar-days" id="bookingCalendarDays">
                                    <!-- Calendar days will be populated by JavaScript -->
                                </div>
                            </div>
                        </div>
                        <div class="row g-2 mt-3">
                            <div class="col-6">
                                <div class="form-control" id="startDateDisplay">Select start date</div>
                            </div>
                            <div class="col-6">
                                <div class="form-control" id="endDateDisplay">Select end date</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Number of Days</label>
                        <input type="number" class="form-control" id="numDays" value="1" min="1" max="30" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Total Price</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="text" class="form-control" id="totalPrice" value="<%= item.price %>" readonly>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-calendar-check"></i> Book Now
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Sticky Booking Bar (shown when minimized or on mobile) -->
<div class="sticky-booking-bar" id="stickyBookingBar">
    <div class="sticky-booking-content">
        <div class="sticky-booking-info">
            <div class="sticky-price-section">
                <div class="sticky-price-amount">$<span id="stickyTotalPrice"><%= item.price %></span> CAD</div>
                <div class="sticky-price-label">total</div>
            </div>
            <div class="sticky-dates-section" id="stickyBookingDates">
                <span class="sticky-dates-text">Select dates</span>
            </div>
        </div>
        <div class="sticky-booking-actions">
            <button type="button" class="btn btn-primary sticky-reserve-btn" id="stickyReserveBtn">
                Reserve
            </button>
        </div>
    </div>
</div>

<!-- Mobile Booking Modal -->
<div class="modal fade" id="mobileBookingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Book This Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="mobileBookingForm">
                    <div class="mb-3">
                        <label class="form-label">Booking Dates</label>
                        <input type="hidden" id="mobileStartDate" required>
                        <input type="hidden" id="mobileEndDate" required>
                        <div class="calendar-section booking-calendar-compact">
                            <div class="calendar-container">
                                <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="mobileBookingPrevMonth">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                    <h6 class="mb-0" id="mobileBookingCurrentMonth">December 2024</h6>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="mobileBookingNextMonth">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </div>
                                <div class="calendar-weekdays">
                                    <div class="calendar-weekday">Sun</div>
                                    <div class="calendar-weekday">Mon</div>
                                    <div class="calendar-weekday">Tue</div>
                                    <div class="calendar-weekday">Wed</div>
                                    <div class="calendar-weekday">Thu</div>
                                    <div class="calendar-weekday">Fri</div>
                                    <div class="calendar-weekday">Sat</div>
                                </div>
                                <div class="calendar-days" id="mobileBookingCalendarDays">
                                    <!-- Calendar days will be populated by JavaScript -->
                                </div>
                            </div>
                        </div>
                        <div class="row g-2 mt-3">
                            <div class="col-6">
                                <div class="form-control" id="mobileStartDateDisplay">Select start date</div>
                            </div>
                            <div class="col-6">
                                <div class="form-control" id="mobileEndDateDisplay">Select end date</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Number of Days</label>
                        <input type="number" class="form-control" id="mobileNumDays" value="1" min="1" max="30" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Total Price</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="text" class="form-control" id="mobileTotalPrice" value="<%= item.price %>" readonly>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-calendar-check"></i> Book Now
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Message Owner Modal -->
<div class="modal fade" id="messageOwnerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-envelope me-2"></i>Message Owner
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="owner-preview mb-3 p-3 bg-light rounded">
                    <div class="d-flex align-items-center">
                        <div class="avatar me-3">
                            <i class="bi bi-person-circle fs-3 text-primary"></i>
                        </div>
                        <div>
                            <h6 class="mb-0">John Doe</h6>
                            <p class="text-muted mb-0 small">Owner of this listing</p>
                        </div>
                    </div>
                </div>
                <form id="messageOwnerForm">
                    <div class="mb-3">
                        <label for="messageSubject" class="form-label">Subject</label>
                        <input type="text" class="form-control" id="messageSubject" placeholder="e.g., Question about availability" required>
                    </div>
                    <div class="mb-3">
                        <label for="messageContent" class="form-label">Message</label>
                        <textarea class="form-control" id="messageContent" rows="6" placeholder="Write your message to the owner here..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="includeBookingDetails" checked>
                            <label class="form-check-label" for="includeBookingDetails">
                                Include booking details (if dates are selected)
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-send me-2"></i>Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="/js/calendar.js"></script>
<script src="/js/gallery.js"></script>
<script>
    // Booking form scroll-based sticky bar functionality
    document.addEventListener('DOMContentLoaded', function() {
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');
        const numDaysInput = document.getElementById('numDays');
        const totalPriceInput = document.getElementById('totalPrice');
        const stickyTotalPrice = document.getElementById('stickyTotalPrice');
        const stickyBookingDates = document.getElementById('stickyBookingDates');
        const stickyReserveBtn = document.getElementById('stickyReserveBtn');
        const bookingForm = document.getElementById('bookingForm');
        const bookingFormContainer = document.getElementById('bookingFormContainer');
        const stickyBookingBar = document.getElementById('stickyBookingBar');
        const startDateDisplay = document.getElementById('startDateDisplay');
        const endDateDisplay = document.getElementById('endDateDisplay');
        const bookingCurrentMonth = document.getElementById('bookingCurrentMonth');
        const bookingCalendarDays = document.getElementById('bookingCalendarDays');
        const bookingPrevMonth = document.getElementById('bookingPrevMonth');
        const bookingNextMonth = document.getElementById('bookingNextMonth');
        const dailyPrice = Number('<%= item.price %>');
        let bookingCalendarMonth = new Date();

        // Check if screen is mobile/small
        function isMobileScreen() {
            return window.innerWidth <= 991.98;
        }

        // Calculate number of days between two dates
        function calculateDays(startDate, endDate) {
            if (!startDate || !endDate) {
                return 1;
            }
            const start = new Date(startDate);
            const end = new Date(endDate);
            
            // Check if end date is before start date
            if (end < start) {
                return 1;
            }
            
            // Calculate difference in milliseconds, then convert to days
            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            // Add 1 to include both start and end days (inclusive)
            return diffDays + 1;
        }

        function formatDisplayDate(dateStr) {
            if (!dateStr) return '';
            const date = new Date(dateStr + 'T00:00:00');
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        function updateCalendarDateDisplays() {
            if (startDateDisplay) {
                startDateDisplay.textContent = startDateInput && startDateInput.value
                    ? formatDisplayDate(startDateInput.value)
                    : 'Select start date';
            }
            if (endDateDisplay) {
                endDateDisplay.textContent = endDateInput && endDateInput.value
                    ? formatDisplayDate(endDateInput.value)
                    : 'Select end date';
            }
        }

        function renderBookingCalendar() {
            if (!bookingCalendarDays || !bookingCurrentMonth) return;

            const year = bookingCalendarMonth.getFullYear();
            const month = bookingCalendarMonth.getMonth();
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                'July', 'August', 'September', 'October', 'November', 'December'];
            bookingCurrentMonth.textContent = `${monthNames[month]} ${year}`;

            const firstDay = new Date(year, month, 1);
            const gridStartDate = new Date(firstDay);
            gridStartDate.setDate(gridStartDate.getDate() - firstDay.getDay());

            bookingCalendarDays.innerHTML = '';
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            for (let i = 0; i < 42; i++) {
                const date = new Date(gridStartDate);
                date.setDate(gridStartDate.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];

                const dayElement = document.createElement('div');
                dayElement.className = 'calendar-day';
                dayElement.textContent = date.getDate();
                dayElement.dataset.date = dateStr;

                if (date.getMonth() !== month) {
                    dayElement.classList.add('other-month');
                }

                const normalizedDate = new Date(dateStr + 'T00:00:00');
                if (normalizedDate.toDateString() === today.toDateString()) {
                    dayElement.classList.add('today');
                }

                if (normalizedDate < today) {
                    dayElement.classList.add('unavailable');
                } else {
                    dayElement.classList.add('available');
                }

                const selectedStart = startDateInput ? startDateInput.value : '';
                const selectedEnd = endDateInput ? endDateInput.value : '';
                if (selectedStart && selectedEnd) {
                    const start = new Date(selectedStart + 'T00:00:00');
                    const end = new Date(selectedEnd + 'T00:00:00');
                    if (normalizedDate >= start && normalizedDate <= end) {
                        dayElement.classList.add('in-range');
                    }
                    if (dateStr === selectedStart || dateStr === selectedEnd) {
                        dayElement.classList.add('selected');
                    }
                } else if (selectedStart && dateStr === selectedStart) {
                    dayElement.classList.add('selected');
                }

                bookingCalendarDays.appendChild(dayElement);
            }
        }

        function handleBookingCalendarDateClick(dateStr) {
            const clickedDate = new Date(dateStr + 'T00:00:00');
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (clickedDate < today) return;

            const selectedStart = startDateInput ? startDateInput.value : '';
            const selectedEnd = endDateInput ? endDateInput.value : '';

            if (!selectedStart || (selectedStart && selectedEnd)) {
                startDateInput.value = dateStr;
                endDateInput.value = '';
            } else {
                const start = new Date(selectedStart + 'T00:00:00');
                if (clickedDate < start) {
                    endDateInput.value = selectedStart;
                    startDateInput.value = dateStr;
                } else {
                    endDateInput.value = dateStr;
                }
            }

            updateNumberOfDays();
            updateStickyBookingBar();
            updateCalendarDateDisplays();
            renderBookingCalendar();
        }

        // Update number of days based on selected dates
        function updateNumberOfDays() {
            const startDate = startDateInput ? startDateInput.value : '';
            const endDate = endDateInput ? endDateInput.value : '';
            const calculatedDays = calculateDays(startDate, endDate);
            
            // Update main form
            if (numDaysInput) {
                numDaysInput.value = calculatedDays;
            }
            
            // Update mobile form
            const mobileNumDays = document.getElementById('mobileNumDays');
            if (mobileNumDays) {
                mobileNumDays.value = calculatedDays;
            }
            
            return calculatedDays;
        }

        // Update sticky booking bar display
        function updateStickyBookingBar() {
            const startDate = startDateInput.value;
            const endDate = endDateInput.value;
            const numDays = updateNumberOfDays();
            const totalPrice = dailyPrice * numDays;

            // Update total price
            if (stickyTotalPrice) {
                stickyTotalPrice.textContent = totalPrice;
            }
            if (totalPriceInput) {
                totalPriceInput.value = totalPrice;
            }

            // Update dates display
            if (stickyBookingDates) {
                if (startDate && endDate) {
                    const start = new Date(startDate);
                    const end = new Date(endDate);
                    const options = { month: 'short', day: 'numeric' };
                    const startStr = start.toLocaleDateString('en-US', options);
                    const endStr = end.toLocaleDateString('en-US', options);
                    stickyBookingDates.innerHTML = `<span class="sticky-dates-text">${startStr} - ${endStr}</span>`;
                } else if (startDate) {
                    const start = new Date(startDate);
                    const options = { month: 'short', day: 'numeric' };
                    const startStr = start.toLocaleDateString('en-US', options);
                    stickyBookingDates.innerHTML = `<span class="sticky-dates-text">${startStr} - Select end date</span>`;
                } else {
                    stickyBookingDates.innerHTML = '<span class="sticky-dates-text">Select dates</span>';
                }
            }
        }

        // Check if booking form is visible in viewport
        function isBookingFormVisible() {
            if (!bookingFormContainer) return true;
            const rect = bookingFormContainer.getBoundingClientRect();
            const windowHeight = window.innerHeight || document.documentElement.clientHeight;
            // Consider form visible if any part is in the viewport
            return rect.top < windowHeight && rect.bottom > 0;
        }

        // Handle scroll-based sticky bar visibility
        function handleStickyBarVisibility() {
            if (isMobileScreen()) {
                // On mobile, hide full booking form but keep sticky bar always visible
                if (bookingFormContainer) {
                    bookingFormContainer.style.display = 'none';
                }
                if (stickyBookingBar) {
                    stickyBookingBar.classList.add('active');
                }
            } else {
                // On desktop, show booking form and manage sticky bar based on scroll
                if (bookingFormContainer) {
                    bookingFormContainer.style.display = '';
                }
                // Show sticky bar when booking form is not visible
                if (isBookingFormVisible()) {
                    stickyBookingBar.classList.remove('active');
                } else {
                    stickyBookingBar.classList.add('active');
                }
            }
        }

        // Initialize
        renderBookingCalendar();
        updateCalendarDateDisplays();
        updateStickyBookingBar();
        handleStickyBarVisibility();

        if (bookingPrevMonth) {
            bookingPrevMonth.addEventListener('click', function() {
                bookingCalendarMonth.setMonth(bookingCalendarMonth.getMonth() - 1);
                renderBookingCalendar();
            });
        }
        if (bookingNextMonth) {
            bookingNextMonth.addEventListener('click', function() {
                bookingCalendarMonth.setMonth(bookingCalendarMonth.getMonth() + 1);
                renderBookingCalendar();
            });
        }
        if (bookingCalendarDays) {
            bookingCalendarDays.addEventListener('click', function(e) {
                if (e.target.classList.contains('calendar-day') && e.target.dataset.date) {
                    handleBookingCalendarDateClick(e.target.dataset.date);
                }
            });
        }

        // Update when dates change (automatically calculate days)
        if (startDateInput) {
            startDateInput.addEventListener('change', function() {
                updateNumberOfDays();
                updateStickyBookingBar();
                updateCalendarDateDisplays();
                renderBookingCalendar();
            });
        }
        if (endDateInput) {
            endDateInput.addEventListener('change', function() {
                updateNumberOfDays();
                updateStickyBookingBar();
                updateCalendarDateDisplays();
                renderBookingCalendar();
            });
        }

        // Mobile booking modal elements
        const mobileBookingModal = document.getElementById('mobileBookingModal');
        const mobileStartDate = document.getElementById('mobileStartDate');
        const mobileEndDate = document.getElementById('mobileEndDate');
        const mobileStartDateDisplay = document.getElementById('mobileStartDateDisplay');
        const mobileEndDateDisplay = document.getElementById('mobileEndDateDisplay');
        const mobileBookingCurrentMonth = document.getElementById('mobileBookingCurrentMonth');
        const mobileBookingCalendarDays = document.getElementById('mobileBookingCalendarDays');
        const mobileBookingPrevMonth = document.getElementById('mobileBookingPrevMonth');
        const mobileBookingNextMonth = document.getElementById('mobileBookingNextMonth');
        const mobileNumDays = document.getElementById('mobileNumDays');
        const mobileTotalPrice = document.getElementById('mobileTotalPrice');
        const mobileBookingForm = document.getElementById('mobileBookingForm');
        let mobileBookingCalendarMonth = new Date();

        function updateMobileCalendarDateDisplays() {
            if (mobileStartDateDisplay) {
                mobileStartDateDisplay.textContent = mobileStartDate && mobileStartDate.value
                    ? formatDisplayDate(mobileStartDate.value)
                    : 'Select start date';
            }
            if (mobileEndDateDisplay) {
                mobileEndDateDisplay.textContent = mobileEndDate && mobileEndDate.value
                    ? formatDisplayDate(mobileEndDate.value)
                    : 'Select end date';
            }
        }

        function renderMobileBookingCalendar() {
            if (!mobileBookingCalendarDays || !mobileBookingCurrentMonth) return;

            const year = mobileBookingCalendarMonth.getFullYear();
            const month = mobileBookingCalendarMonth.getMonth();
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                'July', 'August', 'September', 'October', 'November', 'December'];
            mobileBookingCurrentMonth.textContent = `${monthNames[month]} ${year}`;

            const firstDay = new Date(year, month, 1);
            const gridStartDate = new Date(firstDay);
            gridStartDate.setDate(gridStartDate.getDate() - firstDay.getDay());

            mobileBookingCalendarDays.innerHTML = '';
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            for (let i = 0; i < 42; i++) {
                const date = new Date(gridStartDate);
                date.setDate(gridStartDate.getDate() + i);
                const dateStr = date.toISOString().split('T')[0];

                const dayElement = document.createElement('div');
                dayElement.className = 'calendar-day';
                dayElement.textContent = date.getDate();
                dayElement.dataset.date = dateStr;

                if (date.getMonth() !== month) {
                    dayElement.classList.add('other-month');
                }

                const normalizedDate = new Date(dateStr + 'T00:00:00');
                if (normalizedDate.toDateString() === today.toDateString()) {
                    dayElement.classList.add('today');
                }

                if (normalizedDate < today) {
                    dayElement.classList.add('unavailable');
                } else {
                    dayElement.classList.add('available');
                }

                const selectedStart = mobileStartDate ? mobileStartDate.value : '';
                const selectedEnd = mobileEndDate ? mobileEndDate.value : '';
                if (selectedStart && selectedEnd) {
                    const start = new Date(selectedStart + 'T00:00:00');
                    const end = new Date(selectedEnd + 'T00:00:00');
                    if (normalizedDate >= start && normalizedDate <= end) {
                        dayElement.classList.add('in-range');
                    }
                    if (dateStr === selectedStart || dateStr === selectedEnd) {
                        dayElement.classList.add('selected');
                    }
                } else if (selectedStart && dateStr === selectedStart) {
                    dayElement.classList.add('selected');
                }

                mobileBookingCalendarDays.appendChild(dayElement);
            }
        }

        function handleMobileBookingCalendarDateClick(dateStr) {
            const clickedDate = new Date(dateStr + 'T00:00:00');
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (clickedDate < today) return;

            const selectedStart = mobileStartDate ? mobileStartDate.value : '';
            const selectedEnd = mobileEndDate ? mobileEndDate.value : '';

            if (!selectedStart || (selectedStart && selectedEnd)) {
                mobileStartDate.value = dateStr;
                mobileEndDate.value = '';
            } else {
                const start = new Date(selectedStart + 'T00:00:00');
                if (clickedDate < start) {
                    mobileEndDate.value = selectedStart;
                    mobileStartDate.value = dateStr;
                } else {
                    mobileEndDate.value = dateStr;
                }
            }

            updateMobileFormPrice();
            updateMobileCalendarDateDisplays();
            renderMobileBookingCalendar();
            syncMainForm();
        }

        // Sync mobile form with main form
        function syncMobileForm() {
            if (startDateInput && mobileStartDate) {
                mobileStartDate.value = startDateInput.value;
            }
            if (endDateInput && mobileEndDate) {
                mobileEndDate.value = endDateInput.value;
            }
            if (numDaysInput && mobileNumDays) {
                mobileNumDays.value = numDaysInput.value;
            }
            if (totalPriceInput && mobileTotalPrice) {
                mobileTotalPrice.value = totalPriceInput.value;
            }
            if (startDateInput && startDateInput.value) {
                mobileBookingCalendarMonth = new Date(startDateInput.value + 'T00:00:00');
            } else {
                mobileBookingCalendarMonth = new Date();
            }
            updateMobileCalendarDateDisplays();
            renderMobileBookingCalendar();
        }

        // Sync main form with mobile form
        function syncMainForm() {
            if (mobileStartDate && startDateInput) {
                startDateInput.value = mobileStartDate.value;
            }
            if (mobileEndDate && endDateInput) {
                endDateInput.value = mobileEndDate.value;
            }
            // Calculate and update days automatically
            updateNumberOfDays();
            updateStickyBookingBar();
            updateCalendarDateDisplays();
            renderBookingCalendar();
            updateMobileCalendarDateDisplays();
        }

        // Update mobile form total price
        function updateMobileFormPrice() {
            if (mobileStartDate && mobileEndDate && mobileTotalPrice) {
                const numDays = calculateDays(mobileStartDate.value, mobileEndDate.value);
                const totalPrice = dailyPrice * numDays;
                mobileTotalPrice.value = totalPrice;
                // Update mobile numDays field
                if (mobileNumDays) {
                    mobileNumDays.value = numDays;
                }
            }
        }

        if (mobileBookingPrevMonth) {
            mobileBookingPrevMonth.addEventListener('click', function() {
                mobileBookingCalendarMonth.setMonth(mobileBookingCalendarMonth.getMonth() - 1);
                renderMobileBookingCalendar();
            });
        }

        if (mobileBookingNextMonth) {
            mobileBookingNextMonth.addEventListener('click', function() {
                mobileBookingCalendarMonth.setMonth(mobileBookingCalendarMonth.getMonth() + 1);
                renderMobileBookingCalendar();
            });
        }

        if (mobileBookingCalendarDays) {
            mobileBookingCalendarDays.addEventListener('click', function(e) {
                if (e.target.classList.contains('calendar-day') && e.target.dataset.date) {
                    handleMobileBookingCalendarDateClick(e.target.dataset.date);
                }
            });
        }

        // Mobile booking form submission
        if (mobileBookingForm) {
            mobileBookingForm.addEventListener('submit', function(e) {
                e.preventDefault();
                syncMainForm();
                // Submit the main form
                if (bookingForm) {
                    bookingForm.dispatchEvent(new Event('submit'));
                }
                // Close modal
                const modalInstance = bootstrap.Modal.getInstance(mobileBookingModal);
                if (modalInstance) {
                    modalInstance.hide();
                }
            });
        }

        // Sticky reserve button and dates click handler
        function handleStickyBarClick() {
            if (isMobileScreen()) {
                // On mobile, open booking modal
                syncMobileForm();
                const modal = new bootstrap.Modal(mobileBookingModal);
                modal.show();
            } else {
                // On desktop, scroll to booking form or submit
                if (!startDateInput.value || !endDateInput.value) {
                    bookingFormContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    if (!startDateInput.value) {
                        startDateInput.focus();
                    } else if (!endDateInput.value) {
                        endDateInput.focus();
                    }
                } else {
                    bookingForm.dispatchEvent(new Event('submit'));
                }
            }
        }

        if (stickyReserveBtn) {
            stickyReserveBtn.addEventListener('click', handleStickyBarClick);
        }

        // Make dates section clickable on mobile
        if (stickyBookingDates) {
            stickyBookingDates.addEventListener('click', function() {
                if (isMobileScreen()) {
                    handleStickyBarClick();
                }
            });
        }

        // Handle scroll events with throttling
        let scrollTimeout;
        window.addEventListener('scroll', function() {
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(function() {
                handleStickyBarVisibility();
            }, 10);
        }, { passive: true });

        // Handle window resize
        let resizeTimeout;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(function() {
                handleStickyBarVisibility();
                updateStickyBookingBar();
            }, 250);
        });

        // Message Owner Form Handler
        const messageOwnerForm = document.getElementById('messageOwnerForm');
        const messageSubject = document.getElementById('messageSubject');
        const messageContent = document.getElementById('messageContent');
        const includeBookingDetails = document.getElementById('includeBookingDetails');

        if (messageOwnerForm) {
            messageOwnerForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const subject = messageSubject.value.trim();
                const content = messageContent.value.trim();
                
                if (!subject || !content) {
                    alert('Please fill in both subject and message fields.');
                    return;
                }

                // Build message with optional booking details
                let fullMessage = content;
                
                if (includeBookingDetails.checked && startDateInput && endDateInput) {
                    const startDate = startDateInput.value;
                    const endDate = endDateInput.value;
                    
                    if (startDate && endDate) {
                        const start = new Date(startDate);
                        const end = new Date(endDate);
                        const options = { month: 'long', day: 'numeric', year: 'numeric' };
                        const startStr = start.toLocaleDateString('en-US', options);
                        const endStr = end.toLocaleDateString('en-US', options);
                        const numDays = parseInt(numDaysInput.value) || 1;
                        const totalPrice = dailyPrice * numDays;
                        
                        fullMessage += '\n\n--- Booking Details ---\n';
                        fullMessage += `Start Date: ${startStr}\n`;
                        fullMessage += `End Date: ${endStr}\n`;
                        fullMessage += `Number of Days: ${numDays}\n`;
                        fullMessage += `Total Price: $${totalPrice} CAD`;
                    }
                }

                // Here you would typically send this to your backend
                // For now, we'll just show a success message
                console.log('Message to owner:', {
                    subject: subject,
                    message: fullMessage,
                    owner: 'John Doe',
                    item: '<%= item.title %>'
                });

                // Show success message
                alert('Your message has been sent to the owner! They will respond soon.');
                
                // Reset form and close modal
                messageOwnerForm.reset();
                const modalInstance = bootstrap.Modal.getInstance(document.getElementById('messageOwnerModal'));
                if (modalInstance) {
                    modalInstance.hide();
                }
            });
        }
    });
</script>
<%- include('partials/footer') %> 