<%- include('partials/header') %>

<div class="container rental-container py-5">
    <div class="row">
        <!-- Profile Header -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-2">
                            <div class="profile-avatar text-center">
                                <i class="bi bi-person-circle fs-1 text-primary"></i>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <h3>John Doe</h3>
                            <p class="text-muted mb-2">Member since January 2023</p>
                            <div class="rating">
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star text-warning"></i>
                                <span class="ms-2">4.8 (15 reviews)</span>
                            </div>
                        </div>
                        <div class="col-md-2 text-end">
                            <button class="btn btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit Profile
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Stats</h5>
                </div>
                <div class="card-body">
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Items Listed</h6>
                        <h4 class="text-primary">12</h4>
                    </div>
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Total Rentals</h6>
                        <h4 class="text-primary">45</h4>
                    </div>
                    <div class="stat-item mb-3">
                        <h6 class="text-muted">Earnings</h6>
                        <h4 class="text-primary">$1,250</h4>
                    </div>
                    <div class="stat-item">
                        <h6 class="text-muted">Response Rate</h6>
                        <h4 class="text-primary">98%</h4>
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Account</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-person me-2"></i> Personal Info
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-shield me-2"></i> Security
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-credit-card me-2"></i> Payment Methods
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-decoration-none">
                                <i class="bi bi-bell me-2"></i> Notifications
                            </a>
                        </li>
                        <li>
                            <a href="#" class="text-decoration-none text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h4 class="mb-4">My Listings</h4>
            
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Camera">
                        <div class="card-body">
                            <h6 class="card-title">Professional Camera Kit</h6>
                            <p class="card-text text-muted">$25/day</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-success">Active</span>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                                    <button class="btn btn-sm btn-outline-secondary">View</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Drill">
                        <div class="card-body">
                            <h6 class="card-title">Power Drill Set</h6>
                            <p class="card-text text-muted">$10/day</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-success">Active</span>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                                    <button class="btn btn-sm btn-outline-secondary">View</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %> 