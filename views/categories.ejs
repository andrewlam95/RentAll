<%- include('partials/header') %>

<div class="container rental-container py-5">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">All Categories</h1>
            <p class="text-muted mb-5">Browse through all available categories to find exactly what you need to rent.</p>
        </div>
    </div>

    <div class="row g-4">
        <% categories.forEach(category => { %>
            <div class="col-md-4 col-lg-3">
                <a href="/search?category=<%= category.slug %>" class="text-decoration-none">
                    <div class="card category-card h-100">
                        <div class="card-body text-center">
                            <i class="bi <%= category.icon %> fs-1 mb-3 text-primary"></i>
                            <h5 class="card-title"><%= category.name %></h5>
                            <p class="card-text text-muted">Explore <%= category.name.toLowerCase() %> rentals</p>
                        </div>
                    </div>
                </a>
            </div>
        <% }); %>
    </div>
</div>

<%- include('partials/footer') %> 